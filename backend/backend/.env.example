# ── Existing variables (unchanged) ───────────────────────────────────────────
PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/shiftmaster
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d
BCRYPT_SALT_ROUNDS=10

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=ShiftMaster <noreply@shiftmaster.com>

# Cloudinary (for resume uploads — already used by existing code)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (used in email templates)
FRONTEND_URL=http://localhost:3000

# ── NEW variables (added for new features) ───────────────────────────────────
# Number of days before an unanswered JobRequest auto-expires (default: 7)
JOB_REQUEST_EXPIRY_DAYS=7
